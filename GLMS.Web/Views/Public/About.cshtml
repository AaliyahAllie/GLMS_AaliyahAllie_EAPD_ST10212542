@{
    ViewData["Title"] = "About Us";
}

<section class="page-header">
    <h1>About TechMove Logistics</h1>
    <p>Delivering smarter global logistics through reliable systems and structured service management.</p>
</section>

<div class="row align-items-center g-4">
    <div class="col-lg-6">
        <img src="~/images/about-logistics.jpg"
             class="img-fluid rounded-4 shadow"
             alt="TechMove logistics team and operations" />
    </div>

    <div class="col-lg-6">
        <div class="card p-4">
            <h3>Who We Are</h3>

            <p>
                TechMove Logistics is a global shipping coordination company that helps businesses
                manage international freight, service contracts, and logistics support requests.
            </p>

            <p>
                Our goal is to provide a reliable, transparent, and technology-driven logistics service
                that supports businesses operating across different regions and currencies.
            </p>

            <p>
                The Global Logistics Management System allows TechMove to manage client relationships,
                track contracts, process service requests, and improve compliance across the organisation.
            </p>
        </div>
    </div>
</div>

<section class="feature-section mt-5">
    <h2>Our Values</h2>

    <div class="feature-grid">
        <div class="feature-card">
            <h4>Reliability</h4>
            <p>We help clients manage logistics processes with accuracy and consistency.</p>
        </div>

        <div class="feature-card">
            <h4>Transparency</h4>
            <p>We support clear contract tracking, service visibility, and accountable operations.</p>
        </div>

        <div class="feature-card">
            <h4>Global Reach</h4>
            <p>We coordinate freight movement across multiple international regions.</p>
        </div>

        <div class="feature-card">
            <h4>Innovation</h4>
            <p>We use digital systems to reduce manual work and improve logistics performance.</p>
        </div>
    </div>
</section>