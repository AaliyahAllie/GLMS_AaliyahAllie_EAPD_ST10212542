@{
    ViewData["Title"] = "TechMove Logistics";
}

<section class="hero-section">
    <div class="hero-content">
        <p class="hero-label">Global Logistics Partner</p>
        <h1>Moving freight across borders with confidence.</h1>
        <p>
            TechMove Logistics provides reliable international freight coordination,
            contract-based logistics support, and service request management for global businesses.
        </p>

        <div class="hero-buttons">
            <a asp-controller="Public" asp-action="Services" class="btn btn-primary">Our Services</a>
            <a asp-controller="Public" asp-action="Contact" class="btn btn-light text-primary fw-semibold">Make an Inquiry</a>
        </div>
    </div>
</section>

<section class="feature-section">
    <h2>Why choose TechMove?</h2>

    <div class="feature-grid">
        <div class="feature-card">
            <h4>Global Freight</h4>
            <p>We coordinate international shipping across key global trade routes.</p>
        </div>

        <div class="feature-card">
            <h4>Contract-Based Service</h4>
            <p>Our logistics work is managed through structured contracts and service levels.</p>
        </div>

        <div class="feature-card">
            <h4>Currency-Aware Billing</h4>
            <p>International costs are calculated and reported in South African Rand.</p>
        </div>

        <div class="feature-card">
            <h4>Reliable Support</h4>
            <p>Customers can submit service queries and receive logistics support.</p>
        </div>
    </div>
</section>