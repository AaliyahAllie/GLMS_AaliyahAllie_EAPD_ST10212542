@model GLMS.Web.Models.ServiceRequest

<h1>Service Request Details</h1>

<div class="card p-4">
    <p>
        <strong>Client:</strong>
        @Model.Contract?.Client?.Name
    </p>

    <p>
        <strong>Contract:</strong>
        @Model.Contract?.ServiceLevel
    </p>

    <p>
        <strong>Contract Status:</strong>
        @Model.Contract?.Status
    </p>

    <p>
        <strong>Description:</strong>
        @Model.Description
    </p>

    <p>
        <strong>USD Amount:</strong>
        $@Model.UsdAmount
    </p>

    <p>
        <strong>Exchange Rate:</strong>
        @Model.ExchangeRate
    </p>

    <p>
        <strong>ZAR Cost:</strong>
        R @Model.Cost
    </p>

    <p>
        <strong>Request Status:</strong>
        @Model.Status
    </p>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">
    Back
</a>