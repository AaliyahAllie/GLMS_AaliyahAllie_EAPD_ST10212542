<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - TechMove GLMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GLMS.Web.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container">

                <a class="navbar-brand fw-bold text-primary" asp-controller="Public" asp-action="Index">
                    TechMove GLMS
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Public" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Public" asp-action="About">About Us</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Public" asp-action="Services">Services</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Public" asp-action="Contact">Contact Us</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-primary fw-semibold"
                                   href="#"
                                   role="button"
                                   data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                    Admin Portal
                                </a>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Home" asp-action="Index">
                                            Dashboard
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Clients" asp-action="Index">
                                            Clients
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="Contracts" asp-action="Index">
                                            Contracts
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="ServiceRequests" asp-action="Index">
                                            Service Requests
                                        </a>
                                    </li>

                                    <li><hr class="dropdown-divider" /></li>

                                    <li>
                                        <a class="dropdown-item text-danger fw-semibold"
                                           asp-controller="Account"
                                           asp-action="Logout">
                                            Logout
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary ms-lg-3 px-4"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Admin Login
                                </a>
                            </li>
                        }

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container text-center">
            &copy; 2026 - TechMove Logistics | Global Logistics Management System
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>