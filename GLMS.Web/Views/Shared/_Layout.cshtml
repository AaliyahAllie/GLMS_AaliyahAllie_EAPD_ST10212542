<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - GLMS.Web</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GLMS.Web.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <<ul class="navbar-nav flex-grow-1">
            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Public" asp-action="Index">Home</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Public" asp-action="About">About Us</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Public" asp-action="Services">Services</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" asp-controller="Public" asp-action="Contact">Contact Us</a>
            </li>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Admin Dashboard</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Clients" asp-action="Index">Clients</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="Contracts" asp-action="Index">Contracts</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-dark" asp-controller="ServiceRequests" asp-action="Index">Service Requests</a>
                </li>

                <li class="nav-item ms-auto">
                    <a class="nav-link text-danger fw-semibold" asp-controller="Account" asp-action="Logout">Logout</a>
                </li>
            }
            else
            {
                <li class="nav-item ms-auto">
                    <a class="nav-link text-primary fw-semibold" asp-controller="Account" asp-action="Login">Admin Login</a>
                </li>
            }
        </ul>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

  

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>